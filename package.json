{
  "name": "lled",
  "version": "1.0.0",
  "description": "LLeD — Controlador de tiras LED con sincronización musical y visuales",
  "main": "electron/main.js",
  "scripts": {
    "dev:front": "vite",
    "dev:electron": "electron .",
    "dev:servidor": "python servidor.py",
    "dev": "concurrently -k \"npm run dev:servidor\" \"npm run dev:front\" \"sleep 3 && npm run dev:electron\"",
    "build:front": "vite build",
    "build:backend": "powershell -ExecutionPolicy Bypass -File build_backend.ps1",
    "build:electron": "electron-builder",
    "build": "npm run build:front && npm run build:backend && npm run build:electron"
  },
  "build": {
    "appId": "com.lled.app",
    "productName": "LLeD",
    "directories": {
      "output": "dist_installer",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "dist_backend/servidor", "to": "backend", "filter": ["**/*"] }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh"
    }
  },
  "dependencies": {
    "@ckpack/vue-color": "^1.3.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.0",
    "electron": "^42.4.1",
    "electron-builder": "^24.13.0",
    "vite": "^5.4.0"
  }
}
